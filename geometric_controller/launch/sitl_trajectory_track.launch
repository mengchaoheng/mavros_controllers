<launch>
  <arg name="mav_name" default="iris"/>
  <arg name="fcu_url" default="udp://:14540@127.0.0.1:14557"/>
  <arg name="gcs_url" default="" />
  <arg name="tgt_system" default="1" />
  <arg name="tgt_component" default="1" />
  <arg name="command_input" default="2" />
  <arg name="gazebo_simulation" default="true" />
  <arg name="visualization" default="false"/>
  <arg name="gazebo_gui" default="true"/>
  <arg name="rqt_reconfigure" default="false"/>
  <arg name="run_geometric_controller" default="true"/>
  <arg name="run_trajectory_publisher" default="true"/>
  <arg name="log_output" default="screen" />
  <arg name="fcu_protocol" default="v2.0" />
  <arg name="respawn_mavros" default="false" />

  <arg name="controllerName" default="0" />
  <arg name="trajName" default="4" />
  <arg name="omegaValue" default="0.5" />
  <arg name="legacyOmegaMin" default="0.0" />
  <arg name="legacyOmegaMax" default="5.0" />
  <arg name="figure8HorizontalOmegaMin" default="0.0" />
  <arg name="figure8HorizontalOmegaMax" default="1.5" />
  <arg name="figure8VerticalOmegaMin" default="0.5" />
  <arg name="figure8VerticalOmegaMax" default="1.5" />
  <arg name="helixFlipOmegaMin" default="0.0" />
  <arg name="helixFlipOmegaMax" default="4.0" />
  <arg name="helixFlipYOmegaMin" default="0.0" />
  <arg name="helixFlipYOmegaMax" default="4.0" />
  <arg name="flipLoopSineOmegaMin" default="0.0" />
  <arg name="flipLoopSineOmegaMax" default="4.0" />
  <arg name="fastCircleOmegaMin" default="0.0" />
  <arg name="fastCircleOmegaMax" default="3.5" />
  <arg name="raceTrackCOmegaMin" default="0.0" />
  <arg name="raceTrackCOmegaMax" default="5.0" />
  <arg name="figure8HorizontalAx" default="2.0" />
  <arg name="figure8HorizontalAy" default="2.0" />
  <arg name="figure8HorizontalHc" default="3.0" />
  <arg name="figure8HorizontalTheta0" default="0.0" />
  <arg name="figure8VerticalAy" default="2.0" />
  <arg name="figure8VerticalAz" default="2.0" />
  <arg name="figure8VerticalHc" default="3.0" />
  <arg name="figure8VerticalTheta0" default="-0.7853981633974483" />
  <arg name="helixFlipAy" default="2.0" />
  <arg name="helixFlipAz" default="2.0" />
  <arg name="helixFlipHc" default="3.0" />
  <arg name="helixFlipVx" default="0.30" />
  <arg name="helixFlipTheta0" default="0.0" />
  <arg name="helixFlipYAx" default="2.0" />
  <arg name="helixFlipYAz" default="2.0" />
  <arg name="helixFlipYHc" default="3.0" />
  <arg name="helixFlipYVy" default="0.30" />
  <arg name="helixFlipYTheta0" default="0.0" />
  <arg name="flipLoopSineAy" default="2.0" />
  <arg name="flipLoopSineAz" default="2.0" />
  <arg name="flipLoopSineHc" default="3.0" />
  <arg name="flipLoopSineVx" default="0.0" />
  <arg name="flipLoopSineTheta0" default="0.0" />
  <arg name="fastCircleAx" default="3.0" />
  <arg name="fastCircleAy" default="3.0" />
  <arg name="fastCircleHc" default="3.0" />
  <arg name="fastCircleTheta0" default="0.0" />
  <arg name="trajectoryStartRampDuration" default="2.0" />
  <arg name="waitStartBeforeTrajectory" default="true" />
  <arg name="startPositionTolerance" default="0.18" />
  <arg name="startVelocityTolerance" default="0.25" />
  <arg name="startHoldDuration" default="1.0" />
  <arg name="takeoffHoverZ" default="2.0" />
  <arg name="usePositionTakeoff" default="true" />
  <arg name="positionTakeoffTolerance" default="0.25" />
  <arg name="positionTakeoffVelocityTolerance" default="0.35" />
  <arg name="positionTakeoffHoldDuration" default="1.0" />
  <arg name="indiAccelFeedback" default="1.0" />
  <arg name="indiFilterCutoffHz" default="30.0" />

  <node if="$(arg run_geometric_controller)" pkg="geometric_controller" type="geometric_controller_node" name="geometric_controller" output="screen">
          <param name="mav_name" type="string" value="$(arg mav_name)" />
          <remap from="command/bodyrate_command" to="/mavros/setpoint_raw/attitude"/>
          <param name="ctrl_mode" value="$(arg command_input)" />
          <param name="enable_sim" value="$(arg gazebo_simulation)" />
          <param name="enable_gazebo_state" value="true"/>
          <param name="controllerName" value="$(arg controllerName)" />
          <param name="indiAccelFeedback" value="$(arg indiAccelFeedback)" />
          <param name="indiFilterCutoffHz" value="$(arg indiFilterCutoffHz)" />
          <param name="init_pos_z" value="$(arg takeoffHoverZ)" />
          <param name="use_position_takeoff" value="$(arg usePositionTakeoff)" />
          <param name="position_takeoff_tolerance" value="$(arg positionTakeoffTolerance)" />
          <param name="position_takeoff_velocity_tolerance" value="$(arg positionTakeoffVelocityTolerance)" />
          <param name="position_takeoff_hold_duration" value="$(arg positionTakeoffHoldDuration)" />
          <param name="attctrl_constant" value="0.3"/>
          <param name="KR_x" value="3.0"/>
          <param name="KR_y" value="3.0"/>
          <param name="KR_z" value="2.0"/>
          <param name="KOmega_x" value="1.0"/>
          <param name="KOmega_y" value="1.0"/>
          <param name="KOmega_z" value="1.0"/>
          <param name="normalizedthrust_constant" value="0.02202"/>
          <param name="normalizedthrust_offset" value="0.0"/>
          <param name="Kp_x" value="10.0" />
          <param name="Kp_y" value="10.0" />
          <param name="Kp_z" value="10.0" />
          <param name="Kv_x" value="6.0"/>
          <param name="Kv_y" value="6.0"/>
          <param name="Kv_z" value="6.0"/>
  </node>

  <node if="$(arg run_trajectory_publisher)" pkg="trajectory_publisher" type="trajectory_publisher" name="trajectory_publisher" output="screen">
        <param name="trajName" value="$(arg trajName)" />
        <param name="omegaValue" value="$(arg omegaValue)" />
        <param name="legacyOmegaMin" value="$(arg legacyOmegaMin)" />
        <param name="legacyOmegaMax" value="$(arg legacyOmegaMax)" />
        <param name="figure8HorizontalOmegaMin" value="$(arg figure8HorizontalOmegaMin)" />
        <param name="figure8HorizontalOmegaMax" value="$(arg figure8HorizontalOmegaMax)" />
        <param name="figure8VerticalOmegaMin" value="$(arg figure8VerticalOmegaMin)" />
        <param name="figure8VerticalOmegaMax" value="$(arg figure8VerticalOmegaMax)" />
        <param name="helixFlipOmegaMin" value="$(arg helixFlipOmegaMin)" />
        <param name="helixFlipOmegaMax" value="$(arg helixFlipOmegaMax)" />
        <param name="helixFlipYOmegaMin" value="$(arg helixFlipYOmegaMin)" />
        <param name="helixFlipYOmegaMax" value="$(arg helixFlipYOmegaMax)" />
        <param name="flipLoopSineOmegaMin" value="$(arg flipLoopSineOmegaMin)" />
        <param name="flipLoopSineOmegaMax" value="$(arg flipLoopSineOmegaMax)" />
        <param name="fastCircleOmegaMin" value="$(arg fastCircleOmegaMin)" />
        <param name="fastCircleOmegaMax" value="$(arg fastCircleOmegaMax)" />
        <param name="raceTrackCOmegaMin" value="$(arg raceTrackCOmegaMin)" />
        <param name="raceTrackCOmegaMax" value="$(arg raceTrackCOmegaMax)" />
        <param name="figure8HorizontalAx" value="$(arg figure8HorizontalAx)" />
        <param name="figure8HorizontalAy" value="$(arg figure8HorizontalAy)" />
        <param name="figure8HorizontalHc" value="$(arg figure8HorizontalHc)" />
        <param name="figure8HorizontalTheta0" value="$(arg figure8HorizontalTheta0)" />
        <param name="figure8VerticalAy" value="$(arg figure8VerticalAy)" />
        <param name="figure8VerticalAz" value="$(arg figure8VerticalAz)" />
        <param name="figure8VerticalHc" value="$(arg figure8VerticalHc)" />
        <param name="figure8VerticalTheta0" value="$(arg figure8VerticalTheta0)" />
        <param name="helixFlipAy" value="$(arg helixFlipAy)" />
        <param name="helixFlipAz" value="$(arg helixFlipAz)" />
        <param name="helixFlipHc" value="$(arg helixFlipHc)" />
        <param name="helixFlipVx" value="$(arg helixFlipVx)" />
        <param name="helixFlipTheta0" value="$(arg helixFlipTheta0)" />
        <param name="helixFlipYAx" value="$(arg helixFlipYAx)" />
        <param name="helixFlipYAz" value="$(arg helixFlipYAz)" />
        <param name="helixFlipYHc" value="$(arg helixFlipYHc)" />
        <param name="helixFlipYVy" value="$(arg helixFlipYVy)" />
        <param name="helixFlipYTheta0" value="$(arg helixFlipYTheta0)" />
        <param name="flipLoopSineAy" value="$(arg flipLoopSineAy)" />
        <param name="flipLoopSineAz" value="$(arg flipLoopSineAz)" />
        <param name="flipLoopSineHc" value="$(arg flipLoopSineHc)" />
        <param name="flipLoopSineVx" value="$(arg flipLoopSineVx)" />
        <param name="flipLoopSineTheta0" value="$(arg flipLoopSineTheta0)" />
        <param name="fastCircleAx" value="$(arg fastCircleAx)" />
        <param name="fastCircleAy" value="$(arg fastCircleAy)" />
        <param name="fastCircleHc" value="$(arg fastCircleHc)" />
        <param name="fastCircleTheta0" value="$(arg fastCircleTheta0)" />
        <param name="trajectoryStartRampDuration" value="$(arg trajectoryStartRampDuration)" />
        <param name="waitStartBeforeTrajectory" value="$(arg waitStartBeforeTrajectory)" />
        <param name="startPositionTolerance" value="$(arg startPositionTolerance)" />
        <param name="startVelocityTolerance" value="$(arg startVelocityTolerance)" />
        <param name="startHoldDuration" value="$(arg startHoldDuration)" />
        <param name="initpos_z" value="$(arg takeoffHoverZ)" />
        <param name="reference_type" value="1" />
  </node>

  <node if="$(arg rqt_reconfigure)" pkg="rqt_reconfigure" type="rqt_reconfigure" output="screen" name="rqt_reconfigure" />

  <include file="$(find mavros)/launch/node.launch">
      <arg name="pluginlists_yaml" value="$(find mavros)/launch/px4_pluginlists.yaml" />
      <arg name="config_yaml" value="$(find mavros)/launch/px4_config.yaml" />

      <arg name="fcu_url" value="$(arg fcu_url)" />
      <arg name="gcs_url" value="$(arg gcs_url)" />
      <arg name="tgt_system" value="$(arg tgt_system)" />
      <arg name="tgt_component" value="$(arg tgt_component)" />
      <arg name="log_output" value="$(arg log_output)" />
      <arg name="fcu_protocol" value="$(arg fcu_protocol)" />
      <arg name="respawn_mavros" default="$(arg respawn_mavros)" />
  </include>

  <include file="$(find px4)/launch/posix_sitl.launch">
      <arg name="vehicle" value="$(arg mav_name)"/>
      <arg name="gui" value="$(arg gazebo_gui)"/>
  </include>

  <group if="$(arg visualization)">
      <node type="rviz" name="rviz" pkg="rviz" args="-d $(find geometric_controller)/launch/config_file.rviz" />
  </group>
</launch>
