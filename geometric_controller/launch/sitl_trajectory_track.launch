<launch>
  <arg name="mav_name" default="iris"/>
  <arg name="fcu_url" default="udp://:14540@127.0.0.1:14557"/>
  <arg name="gcs_url" default="" />
  <arg name="tgt_system" default="1" />
  <arg name="tgt_component" default="1" />
  <arg name="command_input" default="2" />
  <arg name="gazebo_simulation" default="true" />
  <arg name="gazebo_gui" default="false" />
  <arg name="visualization" default="true"/>
  <arg name="rqt_reconfigure" default="true"/>
  <arg name="run_geometric_controller" default="true"/>
  <arg name="run_trajectory_publisher" default="true"/>
  <arg name="run_mavros" default="true"/>
  <arg name="run_px4_sitl" default="true"/>
  <arg name="log_output" default="screen" />
  <arg name="fcu_protocol" default="v2.0" />
  <arg name="respawn_mavros" default="false" />

  <arg name="cmdloop_rate" default="250.0" />
  <arg name="controller_type" default="0" />
  <arg name="max_acc" default="50.0" />
  <arg name="KR_r" default="4.0" />
  <arg name="KR_p" default="4.0" />
  <arg name="KR_y" default="4.0" />
  <arg name="normalizedthrust_constant" default="0.022" />
  <arg name="normalizedthrust_offset" default="0.0" />
  <arg name="Kp_x" default="10.0" />
  <arg name="Kp_y" default="10.0" />
  <arg name="Kp_z" default="12.0" />
  <arg name="Kv_x" default="6.0" />
  <arg name="Kv_y" default="6.0" />
  <arg name="Kv_z" default="6.0" />

  <arg name="trajName" default="figure8_horizontal" />
  <arg name="omega_mode" default="0" />
  <arg name="omega_value" default="0.5" />
  <arg name="omega_start" default="0.5" />
  <arg name="omega_end" default="1.5" />
  <arg name="omega_duration" default="20.0" />
  <arg name="path_preview_cycles" default="10.0" />
  <arg name="trajectory_yaw_lock" default="true" />
  <arg name="trajectory_yaw_fixed" default="0.0" />
  <arg name="figure8_horizontal_omega_default" default="0.5" />
  <arg name="figure8_horizontal_omega_min" default="0.05" />
  <arg name="figure8_horizontal_omega_max" default="1.5" />
  <arg name="figure8_vertical_omega_default" default="0.5" />
  <arg name="figure8_vertical_omega_min" default="0.05" />
  <arg name="figure8_vertical_omega_max" default="1.5" />
  <arg name="helix_flip_omega_default" default="1.0" />
  <arg name="helix_flip_omega_min" default="0.05" />
  <arg name="helix_flip_omega_max" default="4.0" />
  <arg name="helix_flip_y_omega_default" default="1.0" />
  <arg name="helix_flip_y_omega_min" default="0.05" />
  <arg name="helix_flip_y_omega_max" default="4.0" />
  <arg name="flip_loop_sine_omega_default" default="1.0" />
  <arg name="flip_loop_sine_omega_min" default="0.05" />
  <arg name="flip_loop_sine_omega_max" default="4.0" />
  <arg name="fast_circle_omega_default" default="0.8" />
  <arg name="fast_circle_omega_min" default="0.05" />
  <arg name="fast_circle_omega_max" default="3.5" />

  <arg name="figure8_horizontal_Ax" default="3.0" />
  <arg name="figure8_horizontal_Ay" default="3.0" />
  <arg name="figure8_horizontal_Hc" default="5.0" />
  <arg name="figure8_horizontal_theta0" default="0.0" />
  <arg name="figure8_vertical_Ay" default="3.0" />
  <arg name="figure8_vertical_Az" default="3.0" />
  <arg name="figure8_vertical_Hc" default="5.0" />
  <arg name="figure8_vertical_theta0" default="-0.7854" />
  <arg name="helix_flip_Ay" default="3.0" />
  <arg name="helix_flip_Az" default="3.0" />
  <arg name="helix_flip_Hc" default="5.0" />
  <arg name="helix_flip_Vx" default="0.3" />
  <arg name="helix_flip_theta0" default="0.0" />
  <arg name="helix_flip_y_Ax" default="3.0" />
  <arg name="helix_flip_y_Az" default="3.0" />
  <arg name="helix_flip_y_Hc" default="5.0" />
  <arg name="helix_flip_y_Vy" default="0.3" />
  <arg name="helix_flip_y_theta0" default="0.0" />
  <arg name="flip_loop_sine_Ay" default="3.0" />
  <arg name="flip_loop_sine_Az" default="3.0" />
  <arg name="flip_loop_sine_Hc" default="5.0" />
  <arg name="flip_loop_sine_Vx" default="0.0" />
  <arg name="flip_loop_sine_theta0" default="0.0" />
  <arg name="fast_circle_Ax" default="3.0" />
  <arg name="fast_circle_Ay" default="3.0" />
  <arg name="fast_circle_Hc" default="5.0" />
  <arg name="fast_circle_theta0" default="0.0" />

  <arg name="initpos_z" default="2.0" />
  <arg name="reference_type" default="2" />
  <arg name="takeoff_before_trajectory" default="true" />
  <arg name="takeoff_position_tolerance" default="0.25" />
  <arg name="takeoff_velocity_tolerance" default="0.5" />
  <arg name="adaptive_trajectory_start_ramp" default="true" />
  <arg name="trajectory_start_ramp_duration" default="5.0" />
  <arg name="trajectory_start_ramp_min_duration" default="0.5" />
  <arg name="trajectory_start_ramp_velocity_limit" default="3.0" />
  <arg name="trajectory_start_ramp_acceleration_limit" default="10.0" />
  <arg name="trajectory_switch_transition_duration" default="3.0" />
  <arg name="trajectory_switch_transition_min_duration" default="1.0" />
  <arg name="trajectory_switch_transition_max_duration" default="12.0" />
  <arg name="trajectory_switch_transition_velocity_limit" default="1.2" />
  <arg name="trajectory_switch_transition_acceleration_limit" default="2.5" />
  <arg name="trajectory_switch_stop_speed_threshold" default="0.2" />

  <node if="$(arg run_geometric_controller)" pkg="geometric_controller" type="geometric_controller_node" name="geometric_controller" output="screen">
        <param name="mav_name" type="string" value="$(arg mav_name)" />
        <remap from="command/bodyrate_command" to="/mavros/setpoint_raw/attitude"/>
        <param name="ctrl_mode" value="$(arg command_input)" />
        <param name="enable_sim" value="$(arg gazebo_simulation)" />
        <param name="enable_gazebo_state" value="true"/>
        <param name="controller_type" value="$(arg controller_type)" />
        <param name="cmdloop_rate" value="$(arg cmdloop_rate)" />
        <param name="max_acc" value="$(arg max_acc)" />
        <param name="KR_r" value="$(arg KR_r)"/>
        <param name="KR_p" value="$(arg KR_p)"/>
        <param name="KR_y" value="$(arg KR_y)"/>
        <param name="normalizedthrust_constant" value="$(arg normalizedthrust_constant)"/>
        <param name="normalizedthrust_offset" value="$(arg normalizedthrust_offset)"/>
        <param name="Kp_x" value="$(arg Kp_x)" />
        <param name="Kp_y" value="$(arg Kp_y)" />
        <param name="Kp_z" value="$(arg Kp_z)" />
        <param name="Kv_x" value="$(arg Kv_x)"/>
        <param name="Kv_y" value="$(arg Kv_y)"/>
        <param name="Kv_z" value="$(arg Kv_z)"/>
  </node>

  <node if="$(arg run_trajectory_publisher)" pkg="trajectory_publisher" type="trajectory_publisher" name="trajectory_publisher" output="screen">
        <param name="trajName" value="$(arg trajName)" />
        <param name="omega_mode" value="$(arg omega_mode)" />
        <param name="omega_value" value="$(arg omega_value)" />
        <param name="omega_start" value="$(arg omega_start)" />
        <param name="omega_end" value="$(arg omega_end)" />
        <param name="omega_duration" value="$(arg omega_duration)" />
        <param name="path_preview_cycles" value="$(arg path_preview_cycles)" />
        <param name="trajectory_yaw_lock" value="$(arg trajectory_yaw_lock)" />
        <param name="trajectory_yaw_fixed" value="$(arg trajectory_yaw_fixed)" />
        <param name="figure8_horizontal_omega_default" value="$(arg figure8_horizontal_omega_default)" />
        <param name="figure8_horizontal_omega_min" value="$(arg figure8_horizontal_omega_min)" />
        <param name="figure8_horizontal_omega_max" value="$(arg figure8_horizontal_omega_max)" />
        <param name="figure8_vertical_omega_default" value="$(arg figure8_vertical_omega_default)" />
        <param name="figure8_vertical_omega_min" value="$(arg figure8_vertical_omega_min)" />
        <param name="figure8_vertical_omega_max" value="$(arg figure8_vertical_omega_max)" />
        <param name="helix_flip_omega_default" value="$(arg helix_flip_omega_default)" />
        <param name="helix_flip_omega_min" value="$(arg helix_flip_omega_min)" />
        <param name="helix_flip_omega_max" value="$(arg helix_flip_omega_max)" />
        <param name="helix_flip_y_omega_default" value="$(arg helix_flip_y_omega_default)" />
        <param name="helix_flip_y_omega_min" value="$(arg helix_flip_y_omega_min)" />
        <param name="helix_flip_y_omega_max" value="$(arg helix_flip_y_omega_max)" />
        <param name="flip_loop_sine_omega_default" value="$(arg flip_loop_sine_omega_default)" />
        <param name="flip_loop_sine_omega_min" value="$(arg flip_loop_sine_omega_min)" />
        <param name="flip_loop_sine_omega_max" value="$(arg flip_loop_sine_omega_max)" />
        <param name="fast_circle_omega_default" value="$(arg fast_circle_omega_default)" />
        <param name="fast_circle_omega_min" value="$(arg fast_circle_omega_min)" />
        <param name="fast_circle_omega_max" value="$(arg fast_circle_omega_max)" />
        <param name="figure8_horizontal_Ax" value="$(arg figure8_horizontal_Ax)" />
        <param name="figure8_horizontal_Ay" value="$(arg figure8_horizontal_Ay)" />
        <param name="figure8_horizontal_Hc" value="$(arg figure8_horizontal_Hc)" />
        <param name="figure8_horizontal_theta0" value="$(arg figure8_horizontal_theta0)" />
        <param name="figure8_vertical_Ay" value="$(arg figure8_vertical_Ay)" />
        <param name="figure8_vertical_Az" value="$(arg figure8_vertical_Az)" />
        <param name="figure8_vertical_Hc" value="$(arg figure8_vertical_Hc)" />
        <param name="figure8_vertical_theta0" value="$(arg figure8_vertical_theta0)" />
        <param name="helix_flip_Ay" value="$(arg helix_flip_Ay)" />
        <param name="helix_flip_Az" value="$(arg helix_flip_Az)" />
        <param name="helix_flip_Hc" value="$(arg helix_flip_Hc)" />
        <param name="helix_flip_Vx" value="$(arg helix_flip_Vx)" />
        <param name="helix_flip_theta0" value="$(arg helix_flip_theta0)" />
        <param name="helix_flip_y_Ax" value="$(arg helix_flip_y_Ax)" />
        <param name="helix_flip_y_Az" value="$(arg helix_flip_y_Az)" />
        <param name="helix_flip_y_Hc" value="$(arg helix_flip_y_Hc)" />
        <param name="helix_flip_y_Vy" value="$(arg helix_flip_y_Vy)" />
        <param name="helix_flip_y_theta0" value="$(arg helix_flip_y_theta0)" />
        <param name="flip_loop_sine_Ay" value="$(arg flip_loop_sine_Ay)" />
        <param name="flip_loop_sine_Az" value="$(arg flip_loop_sine_Az)" />
        <param name="flip_loop_sine_Hc" value="$(arg flip_loop_sine_Hc)" />
        <param name="flip_loop_sine_Vx" value="$(arg flip_loop_sine_Vx)" />
        <param name="flip_loop_sine_theta0" value="$(arg flip_loop_sine_theta0)" />
        <param name="fast_circle_Ax" value="$(arg fast_circle_Ax)" />
        <param name="fast_circle_Ay" value="$(arg fast_circle_Ay)" />
        <param name="fast_circle_Hc" value="$(arg fast_circle_Hc)" />
        <param name="fast_circle_theta0" value="$(arg fast_circle_theta0)" />
        <param name="initpos_z" value="$(arg initpos_z)" />
        <param name="reference_type" value="$(arg reference_type)" />
        <param name="takeoff_before_trajectory" value="$(arg takeoff_before_trajectory)" />
        <param name="takeoff_position_tolerance" value="$(arg takeoff_position_tolerance)" />
        <param name="takeoff_velocity_tolerance" value="$(arg takeoff_velocity_tolerance)" />
        <param name="adaptive_trajectory_start_ramp" value="$(arg adaptive_trajectory_start_ramp)" />
        <param name="trajectory_start_ramp_duration" value="$(arg trajectory_start_ramp_duration)" />
        <param name="trajectory_start_ramp_min_duration" value="$(arg trajectory_start_ramp_min_duration)" />
        <param name="trajectory_start_ramp_velocity_limit" value="$(arg trajectory_start_ramp_velocity_limit)" />
        <param name="trajectory_start_ramp_acceleration_limit" value="$(arg trajectory_start_ramp_acceleration_limit)" />
        <param name="trajectory_switch_transition_duration" value="$(arg trajectory_switch_transition_duration)" />
        <param name="trajectory_switch_transition_min_duration" value="$(arg trajectory_switch_transition_min_duration)" />
        <param name="trajectory_switch_transition_max_duration" value="$(arg trajectory_switch_transition_max_duration)" />
        <param name="trajectory_switch_transition_velocity_limit" value="$(arg trajectory_switch_transition_velocity_limit)" />
        <param name="trajectory_switch_transition_acceleration_limit" value="$(arg trajectory_switch_transition_acceleration_limit)" />
        <param name="trajectory_switch_stop_speed_threshold" value="$(arg trajectory_switch_stop_speed_threshold)" />
  </node>

  <node if="$(arg rqt_reconfigure)" pkg="rqt_reconfigure" type="rqt_reconfigure" output="screen" name="rqt_reconfigure" />

  <include if="$(arg run_mavros)" file="$(find mavros)/launch/node.launch">
      <arg name="pluginlists_yaml" value="$(find mavros)/launch/px4_pluginlists.yaml" />
      <arg name="config_yaml" value="$(find mavros)/launch/px4_config.yaml" />

      <arg name="fcu_url" value="$(arg fcu_url)" />
      <arg name="gcs_url" value="$(arg gcs_url)" />
      <arg name="tgt_system" value="$(arg tgt_system)" />
      <arg name="tgt_component" value="$(arg tgt_component)" />
      <arg name="log_output" value="$(arg log_output)" />
      <arg name="fcu_protocol" value="$(arg fcu_protocol)" />
      <arg name="respawn_mavros" default="$(arg respawn_mavros)" />
  </include>

  <include if="$(arg run_px4_sitl)" file="$(find px4)/launch/posix_sitl.launch">
      <arg name="vehicle" value="$(arg mav_name)"/>
      <arg name="gui" value="$(arg gazebo_gui)"/>
  </include>

  <group if="$(arg visualization)">
      <node type="rviz" name="rviz" pkg="rviz" args="-d $(find geometric_controller)/launch/config_file.rviz" />
  </group>
</launch>
